# Godot 4+ specific ignores
.godot/
*.tmp
# Godot import/uid artifacts are regenerated locally; not needed since assets
# are loaded at runtime via Image.load_from_file() rather than as imported resources.
*.import
*.uid

# OS-specific
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Build artifacts
*.exe
*.apk
*.ipa
*.x86_64
*.dll
*.so
*.dylib

# User-specific
*.log

# Local opencode config (contains API keys)
opencode.json
.opencode/mcp.json
